# ===========================================
# Paso 0 — Variables de entorno (una sola fuente)
# Copia a .env y rellena los valores. Luego ejecuta: ./scripts/prepare-env.sh
# ===========================================

# Base de datos (MariaDB)
# Si tu proveedor da DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS, monta la URL así:
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Backend
JWT_SECRET=change-me-in-production
# Tiempo máximo de sesión (JWT). Ej.: 8h, 12h, 1d, 5d, 7d
JWT_EXPIRES_IN=5d
CORS_ORIGIN=http://localhost:3000
# Producción (mismo front en HTTPS; incluye apex si redirige o sirve sin www):
# CORS_ORIGIN=https://www.avvalecompanion.app,https://avvalecompanion.app

# Frontend (URL pública del backend; en local suele ser http://localhost:4000)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Producción con Next y proxy /api en el mismo host (típico Coolify):
# NEXT_PUBLIC_API_URL=https://www.avvalecompanion.app
# URL pública para adjuntos en webhooks Make (si difiere del front; si no, omite):
# BACKEND_PUBLIC_URL=https://www.avvalecompanion.app
# Si el proxy solo enruta /api/* al Nest (mismo dominio que el front), pon false. Si el API es un host dedicado (p. ej. api.dominio.com) con Nest en la raíz, déjalo en true o sin definir.
# NEXT_PUBLIC_API_STRIP_PREFIX=true

# Adjuntos: directorio donde se guardan los archivos descargados desde URLs escaneadas (opcional; por defecto ./uploads)
# ATTACHMENTS_DIR=./uploads

# Redis — cola BullMQ para envío asíncrono a Make (backend)
REDIS_URL=redis://127.0.0.1:6379/0
# BULL_PREFIX=avvale

# Make.com — Orquestación de envíos (webhook personalizado)
# URL del escenario "Custom webhook" en Make (copiar desde el editor del escenario).
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxx
# Opcional: timeout (ms) del POST desde el backend hacia Make. Si Make tarda en responder 200, sube este valor (p. ej. 60000).
# MAKE_WEBHOOK_TIMEOUT_MS=30000
# Opcional: cabecera X-Webhook-Secret; valida en Make con un filtro (header = valor).
# MAKE_WEBHOOK_SECRET=
# Secreto compartido para el callback HTTP POST desde Make hacia el backend (ver docs/MAKE.md).
# MAKE_CALLBACK_SECRET=

# --- Correo transaccional (enlace mágico de login y futuros avisos) ---
# Remitente (configurar SPF/DKIM en el dominio en tu proveedor de correo).
# MAIL_FROM=no-reply@avvalecompanion.app
# MAIL_FROM_NAME=Avvale Companion
# Opcional: logo del correo (HTTPS). Por defecto, mismo asset que la pantalla de login.
# MAIL_LOGO_URL=https://www.sap.com/dam/application/shared/logos/customer/a-g/avvale-customer-logo.png
# Línea bajo el logo en el correo (asunto y plantilla).
# MAIL_PRODUCT_TAGLINE=Activaciones · Avvale
# En local sin SMTP: imprime el enlace en logs del backend.
# MAIL_SKIP_SEND=true
# SMTP (salida; IMAP no se usa en el backend, solo para leer correo en un cliente)
# Ejemplo IONOS (buzón no-reply u otro que tengáis en el dominio):
# SMTP_HOST=smtp.ionos.es
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=no-reply@avvalecompanion.app
# SMTP_PASS=contraseña_del_buzón
# (IMAP solo cliente: imap.ionos.es puerto 993 SSL — no va en esta app)
# URL del front donde se abre el enlace (sin query; se añade ?token=).
# MAGIC_LINK_BASE_URL=http://localhost:3000/login/magic
# MAGIC_LINK_TTL_MINUTES=15
# Opcional: firma distinta a JWT para el hash del token (por defecto usa JWT_SECRET).
# MAGIC_LINK_SECRET=
