# Copy to .env and adjust.

# Postgres
DB_PASSWORD=kyc_secret

# App port exposed on host
PORT=3388

# JWT — use a long random string in production (e.g. openssl rand -base64 64)
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Initial admin user (seeded on first boot if the users table is empty)
ADMIN_EMAIL=admin@kyc.local
ADMIN_PASSWORD=kycadmin2026
ADMIN_NAME=Admin
