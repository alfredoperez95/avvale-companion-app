# Conexión a MariaDB (una de las dos formas)

# Opción 1: URL completa (recomendada)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Opción 2: Si tu proveedor da variables separadas, monta la URL así:
# DATABASE_URL="mysql://DB_USER:DB_PASS@DB_HOST:DB_PORT/DB_NAME"

# Runtime del proceso Nest (Coolify: en el servicio del BACKEND, no en el del frontend)
# - production → activa Helmet en src/main.ts (cabeceras HTTP de seguridad).
# - development o sin definir → sin Helmet (típico en local).
# El NODE_ENV del frontend es independiente y no activa Helmet en el API.
# NODE_ENV=production

# Auth
JWT_SECRET=change-me-in-production
# Tiempo máximo de sesión (JWT de acceso). Ejemplos: 8h, 12h, 1d, 5d, 7d
JWT_EXPIRES_IN=5d
CORS_ORIGIN=http://localhost:3000
# Producción: un origen por entrada, separados por coma (sin espacios). Ejemplo:
# CORS_ORIGIN=https://www.avvalecompanion.app,https://avvalecompanion.app

# Tamaño máximo del body JSON/urlencoded (Express). Default en código: 50mb. Webhooks RFQ con base64.
# HTTP_BODY_LIMIT=50mb

# Cifrado credenciales Anthropic por usuario (32 bytes).
# Acepta:
# - hex de 64 caracteres (32 bytes)
# - base64 que decodifique a 32 bytes
# - texto raw UTF-8 de 32 bytes
# Ejemplo para generar base64 (macOS/Linux):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ANTHROPIC_API_KEY_MASTER_KEY=

# Redis (BullMQ — cola de envío a Make)
REDIS_URL=redis://127.0.0.1:6379/0
# Alternativa sin URL:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
BULL_PREFIX=avvale
# ACTIVATION_SEND_QUEUE_ATTEMPTS=5
# ACTIVATION_SEND_QUEUE_BACKOFF_MS=5000

# Análisis RFQs (cola BullMQ + límites)
# RFQ_QUEUE_ATTEMPTS=3
# RFQ_QUEUE_BACKOFF_MS=8000
# RFQ_MAX_ATTACHMENTS_PER_ANALYSIS=10
# Máximo por fichero decodificado (default 50 MiB si no se define; alinear con HTTP_BODY_LIMIT)
# RFQ_MAX_FILE_BYTES=52428800
# Suma aproximada de todos los adjuntos en un análisis (default 50 MiB)
# RFQ_MAX_TOTAL_BYTES_PER_ANALYSIS=52428800
# RFQ_CONTEXT_MAX_CHARS=120000
# Primera pasada de síntesis (económica). Segunda: RFQ_SYNTHESIS_ESCALATION_MODEL si hay adjunto no-PDF con extracción OK o si la primera no devuelve JSON válido.
# RFQ_SYNTHESIS_MODEL=haiku
# RFQ_SYNTHESIS_ESCALATION_MODEL=sonnet
# RFQ_CHAT_MODEL=haiku

# MEDDPICC: modelo Anthropic para análisis de deals (haiku | sonnet | opus). Por defecto: sonnet.
# MEDDPICC_MODEL=sonnet

# ElevenLabs ConvAI: webhook post-llamada (HMAC). En el panel de ElevenLabs, apunta a:
# POST https://<tu-backend>/webhooks/elevenlabs/meddpicc
# Secreto = el generado al crear el webhook (no la API key).
ELEVENLABS_WEBHOOK_SECRET=change-me-in-production

# Debug: habilita endpoint autenticado para simular un post_call_transcription y ver qué se persiste en `notes`.
# Recomendado SOLO en local.
# ALLOW_CONVAI_WEBHOOK_SIMULATE=true

# Webhook Make → entrada por email (POST /webhooks/rfq-email/inbound)
# RFQ_EMAIL_WEBHOOK_SECRET=

# Timeout (ms) en PENDING_CALLBACK sin callback de Make (watchdog). Compat: MAKE_READY_TO_SEND_TIMEOUT_MS
# MAKE_PENDING_CALLBACK_TIMEOUT_MS=30000

# Make.com (envíos)
# MAKE_WEBHOOK_URL=
# POST saliente al webhook de Make: tiempo máximo de espera (ms). Por defecto 30000.
# MAKE_WEBHOOK_TIMEOUT_MS=30000
# MAKE_WEBHOOK_SECRET=
# MAKE_CALLBACK_SECRET=

# Correo (enlace mágico). Ver también .env.example en la raíz del repo.
# MAIL_FROM=no-reply@avvalecompanion.app
# MAIL_FROM_NAME=Avvale Companion
# MAIL_LOGO_URL=   # opcional; default = logo login SAP/Avvale
# MAIL_PRODUCT_TAGLINE=Activaciones · Avvale
# MAIL_SKIP_SEND=true
# IONOS ejemplo: smtp.ionos.es:587 TLS (SMTP_USER = email completo del buzón)
# SMTP_HOST=smtp.ionos.es
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=no-reply@avvalecompanion.app
# SMTP_PASS=
# MAGIC_LINK_BASE_URL=http://localhost:3000/login/magic
# URL pública del frontend para enlaces en correos (p. ej. notificación RFQ completada → /launcher/rfq-analysis/:id).
# Si no se define, se deduce del origen de MAGIC_LINK_BASE_URL.
# APP_PUBLIC_URL=http://localhost:3000
# MAGIC_LINK_TTL_MINUTES=15
# MAGIC_LINK_SECRET=

# Invitaciones de registro (admin envía correo con enlace a /login/register-invite?token=…)
# INVITE_REGISTRATION_BASE_URL=http://localhost:3000/login/register-invite
# INVITE_REGISTRATION_TTL_HOURS=168
# INVITE_TOKEN_SECRET=   # opcional; si no, usa MAGIC_LINK_SECRET o JWT_SECRET
