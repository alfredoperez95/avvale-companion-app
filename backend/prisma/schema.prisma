generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

/** Sector / industria Avvale (perfil y administración). */
enum UserIndustry {
  ENERGY_PUBLIC_SECTOR
  CONSUMER_MARKETS
  LIFESTYLE_SERVICES
  INDUSTRIAL_CORPORATE_MARKETS
}

/** Puesto / rol funcional en perfil y administración. */
enum UserPosition {
  GROWTH_MANAGING_DIRECTOR
  INDUSTRY_DIRECTOR
  ACCOUNT_MANAGER
}

enum ActivationStatus {
  DRAFT
  PENDING_CALLBACK
  SENT
  QUEUED
  PROCESSING
  RETRYING
  FAILED
}

enum ProjectType {
  CONSULTORIA
  SW
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @map("phone")
  name         String?
  lastName     String?  @map("last_name")
  position     UserPosition? @map("position")
  industry     UserIndustry? @map("industry")
  appearance   String?  @map("appearance")
  avatarPath   String?  @map("avatar_path")
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  /** Orden de mosaicos en App Launcher: permutación de activations, pipeline, yubiq, rfqAnalysis, meddpicc (5 ids) */
  launcherTileOrder Json? @map("launcher_tile_order")

  activations     Activation[]
  ownedAreas      Area[]          @relation("UserOwnedAreas")
  emailTemplates  EmailTemplate[]
  emailSignature  EmailSignature? @relation("UserEmailSignature")
  anthropicCredential UserAnthropicCredential?
  magicLoginTokens   MagicLoginToken[]
  rfqAnalyses        RfqAnalysis[]
  meddpiccDeals      MeddpiccDeal[]
  sentInvitations    UserInvitation[] @relation("UserInvitedBy")
  kycChatSessions    KycChatSession[]
  kycFacts           KycFact[]

  @@map("users")
}

/** Invitación pendiente de registro (token por email; se elimina o marca al aceptar). */
model UserInvitation {
  id               String         @id @default(uuid())
  email            String         @unique @map("email")
  name             String         @map("name")
  lastName         String         @map("last_name")
  position         UserPosition?  @map("position")
  industry         UserIndustry?  @map("industry")
  role             UserRole       @default(USER) @map("role")
  tokenHash        String         @unique @map("token_hash") @db.VarChar(64)
  invitedByUserId  String         @map("invited_by_user_id")
  expiresAt        DateTime       @map("expires_at")
  usedAt           DateTime?      @map("used_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  invitedBy User @relation("UserInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@map("user_invitations")
}

/** Origen del workspace: creado en app o vía email (Make). */
enum RfqWorkspaceSource {
  MANUAL
  EMAIL
}

enum RfqAnalysisStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

/** Tipo de cada fuente de entrada dentro del análisis. */
enum RfqSourceKind {
  FILE
  EMAIL_BODY
  THREAD_CONTEXT
  MANUAL_NOTE
}

enum RfqExtractionStatus {
  PENDING
  OK
  FAILED
  SKIPPED
}

enum RfqMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RfqJobPhase {
  INGEST
  EXTRACT
  NORMALIZE
  SYNTHESIZE
}

/** Workspace persistente por oportunidad / RFQ. */
model RfqAnalysis {
  id                  String              @id @default(uuid())
  userId              String              @map("user_id")
  sourceType          RfqWorkspaceSource  @map("source_type")
  status              RfqAnalysisStatus   @default(DRAFT)
  title               String              @db.VarChar(512)
  manualContext       String?             @map("manual_context") @db.Text
  originEmail         String?             @map("origin_email") @db.VarChar(320)
  originSubject       String?             @map("origin_subject") @db.VarChar(998)
  originThreadContext String?             @map("origin_thread_context") @db.Text
  lastProcessedAt     DateTime?           @map("last_processed_at")
  failureReason       String?             @map("failure_reason") @db.Text
  bullJobId           String?             @map("bull_job_id") @db.VarChar(128)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources  RfqAnalysisSource[]
  insights RfqAnalysisInsight[]
  messages RfqAnalysisMessage[]
  jobEvents RfqAnalysisJobEvent[]

  @@index([userId])
  @@index([status])
  @@map("rfq_analyses")
}

model RfqAnalysisSource {
  id                String               @id @default(uuid())
  analysisId        String               @map("analysis_id")
  kind              RfqSourceKind        @map("kind")
  sortOrder         Int                  @default(0) @map("sort_order")
  fileName          String?              @map("file_name") @db.VarChar(512)
  mimeType          String?              @map("mime_type") @db.VarChar(255)
  storagePath       String?              @map("storage_path") @db.VarChar(1024)
  extractedText     String?              @map("extracted_text") @db.LongText
  extractionStatus  RfqExtractionStatus  @default(PENDING) @map("extraction_status")
  extractionError   String?              @map("extraction_error") @db.Text
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  analysis RfqAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("rfq_analysis_sources")
}

model RfqAnalysisInsight {
  id                   String   @id @default(uuid())
  analysisId           String   @map("analysis_id")
  version              Int      @default(1)
  executiveSummary     String?  @map("executive_summary") @db.Text
  opportunityType      String?  @map("opportunity_type") @db.VarChar(512)
  detectedTechnologies Json?    @map("detected_technologies")
  avvaleAreas          Json?    @map("avvale_areas")
  functionalVision     String?  @map("functional_vision") @db.Text
  technicalVision      String?  @map("technical_vision") @db.Text
  risksAndUnknowns     String?  @map("risks_and_unknowns") @db.Text
  recommendedQuestions Json?    @map("recommended_questions")
  confidenceNotes      String?  @map("confidence_notes") @db.Text
  rawModelOutput       String?  @map("raw_model_output") @db.LongText
  synthesisModelId     String?  @map("synthesis_model_id") @db.VarChar(128)
  createdAt            DateTime @default(now()) @map("created_at")

  analysis RfqAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("rfq_analysis_insights")
}

model RfqAnalysisMessage {
  id         String         @id @default(uuid())
  analysisId String         @map("analysis_id")
  role       RfqMessageRole
  content    String         @db.LongText
  metadata   Json?
  modelId    String?        @map("model_id") @db.VarChar(128)
  createdAt  DateTime       @default(now()) @map("created_at")

  analysis RfqAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("rfq_analysis_messages")
}

model RfqAnalysisJobEvent {
  id           String       @id @default(uuid())
  analysisId   String       @map("analysis_id")
  phase        RfqJobPhase
  status       String       @db.VarChar(32)
  detail       Json?
  modelId      String?      @map("model_id") @db.VarChar(128)
  promptHash   String?      @map("prompt_hash") @db.VarChar(64)
  errorMessage String?      @map("error_message") @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  analysis RfqAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("rfq_analysis_job_events")
}

/** Tokens de un solo uso para login por enlace mágico (hash almacenado, no el token en claro). */
model MagicLoginToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("magic_login_tokens")
}

model UserAnthropicCredential {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  apiKeyCiphertext String   @map("api_key_ciphertext") @db.Text
  apiKeyIv         String   @map("api_key_iv") @db.Text
  apiKeyTag        String   @map("api_key_tag") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_anthropic_credentials")
}

/** Deal cualificado MEDDPICC (oportunidad B2B). */
model MeddpiccDeal {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  name       String   @db.VarChar(512)
  company    String   @default("") @db.VarChar(512)
  ownerLabel String?  @map("owner_label") @db.VarChar(200)
  value      String   @default("") @db.VarChar(200)
  context    String?  @db.Text
  scores     Json     @default("{}")
  answers    Json     @default("{}")
  notes      Json     @default("{}")
  status     String   @default("active") @db.VarChar(32)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  history      MeddpiccHistory[]
  attachments  MeddpiccDealAttachment[]

  @@index([userId])
  @@index([status])
  @@map("meddpicc_deals")
}

/** Adjuntos del contexto del deal; texto extraído a markdown para IA y visualización. */
model MeddpiccDealAttachment {
  id                  String   @id @default(uuid())
  dealId              String   @map("deal_id")
  fileName            String   @map("file_name") @db.VarChar(512)
  mimeType            String   @map("mime_type") @db.VarChar(255)
  storagePath         String   @map("storage_path") @db.VarChar(1024)
  extractedMarkdown   String   @map("extracted_markdown") @db.LongText
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")

  deal MeddpiccDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("meddpicc_deal_attachments")
}

/** Historial de cambios de score por dimensión MEDDPICC. */
model MeddpiccHistory {
  id         BigInt   @id @default(autoincrement())
  dealId     String   @map("deal_id")
  dimension  String   @db.VarChar(16)
  score      Int?
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  deal MeddpiccDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt(sort: Desc)])
  @@map("meddpicc_history")
}

model Area {
  id            String        @id @default(uuid())
  name          String
  directorName  String?       @map("director_name")
  directorEmail String?       @map("director_email")
  createdAt     DateTime      @default(now()) @map("created_at")
  /** null = árbol del sistema (plantilla para clonar; solo admin edita). */
  ownerUserId   String?       @map("owner_user_id")

  ownerUser       User?            @relation("UserOwnedAreas", fields: [ownerUserId], references: [id], onDelete: Cascade)
  subAreas        SubArea[]
  activationAreas ActivationArea[]

  @@index([ownerUserId])
  @@map("areas")
}

model SubArea {
  id        String           @id @default(uuid())
  areaId    String           @map("area_id")
  name      String
  createdAt DateTime         @default(now()) @map("created_at")

  area                Area                 @relation(fields: [areaId], references: [id], onDelete: Cascade)
  contacts            SubAreaContact[]
  activationSubAreas  ActivationSubArea[]

  @@map("sub_areas")
}

model SubAreaContact {
  id          String  @id @default(uuid())
  subAreaId   String  @map("sub_area_id")
  name        String
  email       String
  isProjectJp Boolean @default(false) @map("is_project_jp")

  subArea SubArea @relation(fields: [subAreaId], references: [id], onDelete: Cascade)

  @@map("sub_area_contacts")
}

model Activation {
  id               String           @id @default(uuid())
  activationNumber Int              @unique @default(autoincrement()) @map("activation_number") @db.UnsignedInt
  createdAt        DateTime         @default(now()) @map("created_at")
  createdBy        String           @map("created_by")
  createdByUserId  String           @map("created_by_user_id")
  status           ActivationStatus @default(DRAFT)
  recipientTo      String           @map("recipient_to") @db.Text
  recipientCc      String?          @map("recipient_cc") @db.Text
  subject          String
  projectName      String           @map("project_name")
  client           String?          @map("client")
  offerCode        String           @map("offer_code")
  projectAmount    String?          @map("project_amount")
  projectType      ProjectType?     @map("project_type")
  hubspotUrl       String?          @map("hubspot_url")
  projectJpName    String?          @map("project_jp_name")
  projectJpEmail   String?          @map("project_jp_email")
  projectJpSource  String?          @map("project_jp_source")
  body             String?          @map("body") @db.Text
  attachmentUrls   String?          @map("attachment_urls") @db.Text
  attachmentNames  String?          @map("attachment_names") @db.Text
  makeSentAt          DateTime?        @map("make_sent_at")
  makeRunId           String?          @map("make_run_id")
  errorMessage        String?          @map("error_message") @db.Text
  lastStatusAt        DateTime?        @map("last_status_at")
  queuedAt            DateTime?        @map("queued_at")
  processingStartedAt DateTime?        @map("processing_started_at")
  sendAttemptCount    Int              @default(0) @map("send_attempt_count")
  bullJobId           String?          @map("bull_job_id")

  createdByUser        User                 @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  activationAreas      ActivationArea[]
  activationSubAreas   ActivationSubArea[]
  attachments          ActivationAttachment[]

  @@index([status])
  @@map("activations")
}

model ActivationAttachment {
  id           String   @id @default(uuid())
  activationId String   @map("activation_id")
  originalUrl  String   @map("original_url") @db.Text
  storedPath   String   @map("stored_path")
  fileName     String   @map("file_name")
  contentType  String?  @map("content_type")
  publicToken  String?  @unique @map("public_token")
  publicExpiresAt DateTime? @map("public_expires_at")
  publishedAt DateTime? @map("published_at")
  createdAt    DateTime @default(now()) @map("created_at")

  activation Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)

  @@map("activation_attachments")
}

model ActivationArea {
  activationId String @map("activation_id")
  areaId       String @map("area_id")

  activation Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  area       Area       @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([activationId, areaId])
  @@map("activation_areas")
}

model ActivationSubArea {
  activationId String  @map("activation_id")
  subAreaId    String  @map("sub_area_id")

  activation Activation @relation(fields: [activationId], references: [id], onDelete: Cascade)
  subArea     SubArea   @relation(fields: [subAreaId], references: [id], onDelete: Cascade)

  @@id([activationId, subAreaId])
  @@map("activation_sub_areas")
}

model CcContact {
  id          String   @id @default(uuid())
  name        String
  email       String
  isProjectJp Boolean  @default(false) @map("is_project_jp")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("cc_contacts")
}

model BillingAdminContact {
  id        String   @id @default(uuid())
  name      String
  email     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("billing_admin_contacts")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String   @db.LongText
  createdAt DateTime @default(now()) @map("created_at")
  /** null = plantilla del sistema (solo admin). */
  userId    String?  @map("user_id")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_templates")
}

/** Firma HTML por usuario (una fila por usuario; userId obligatorio tras script migrate-user-scoped-config). */
model EmailSignature {
  id        String   @id @default(uuid())
  userId    String?  @unique @map("user_id")
  content   String   @db.LongText
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation("UserEmailSignature", fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_signature")
}

// ---------------------------------------------------------------------------
// KYC (Client Knowledge) — tablas prefijadas kyc_*, espejo lógico de
// services/kyc/init.sql; auth propia de KYC no se persiste (usa User de Companion).
// ---------------------------------------------------------------------------

enum KycOrgRelationType {
  aliado
  bloqueador
  influencer
  mentor
  rival
  otro
}

enum KycChatMessageRole {
  user
  assistant
  system
  tool
}

enum KycChatSessionType {
  research
  intake
}

enum KycOpenQuestionStatus {
  open
  resolved
  skipped
}

enum KycSignalSentiment {
  positive
  neutral
  negative
  mixed
}

model KycCompany {
  id        BigInt   @id @default(autoincrement())
  name      String
  sector    String?
  industry  String?
  city      String?
  country   String?  @default("Spain")
  website   String?
  revenue   String?
  employees String?
  techStack String?  @map("tech_stack")
  source    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile           KycProfile?
  contacts          KycContact[]
  orgMembers        KycOrgMember[]
  orgRelationships  KycOrgRelationship[]
  signals           KycSignal[]
  facts             KycFact[]
  chatSessions      KycChatSession[]
  openQuestions     KycOpenQuestion[]

  @@index([name])
  @@index([sector])
  @@index([industry])
  @@map("kyc_companies")
}

model KycContact {
  id        BigInt   @id @default(autoincrement())
  companyId BigInt?  @map("company_id")
  firstName String   @map("first_name")
  lastName  String?  @map("last_name")
  email     String?
  phone     String?
  jobTitle  String?  @map("job_title")
  linkedin  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    KycCompany?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  orgMembers KycOrgMember[]

  @@index([companyId])
  @@map("kyc_contacts")
}

model KycProfile {
  companyId         BigInt    @id @map("company_id")
  economics         Json      @default("{}")
  businessModel     Json      @default("{}") @map("business_model")
  customers         Json      @default("{}")
  techStack         Json      @default("{}") @map("tech_stack")
  criticalProcesses Json      @default("{}") @map("critical_processes")
  sectorContext     Json      @default("{}") @map("sector_context")
  competencia       Json      @default("{}")
  summary           String?   @db.Text
  confidenceScore   Int?      @default(0) @map("confidence_score")
  strategic         Boolean   @default(false)
  lastEnrichedAt    DateTime? @map("last_enriched_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company KycCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([strategic])
  @@map("kyc_profiles")
}

model KycOrgMember {
  id          BigInt   @id @default(autoincrement())
  companyId   BigInt   @map("company_id")
  contactId   BigInt?  @map("contact_id")
  name        String
  role        String?
  area        String?
  level       Int?
  reportsToId BigInt?  @map("reports_to_id")
  linkedin    String?
  notes       String?  @db.Text
  source      String?  @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company    KycCompany   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    KycContact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  reportsTo  KycOrgMember?  @relation("KycOrgHierarchy", fields: [reportsToId], references: [id], onDelete: SetNull)
  reportees  KycOrgMember[] @relation("KycOrgHierarchy")
  relFrom    KycOrgRelationship[] @relation("KycOrgRelFrom")
  relTo      KycOrgRelationship[] @relation("KycOrgRelTo")

  @@index([companyId])
  @@index([reportsToId])
  @@map("kyc_org_members")
}

model KycOrgRelationship {
  id           BigInt   @id @default(autoincrement())
  companyId    BigInt   @map("company_id")
  fromMemberId BigInt   @map("from_member_id")
  toMemberId   BigInt   @map("to_member_id")
  type         KycOrgRelationType
  strength     Int?     @default(3)
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  company    KycCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromMember KycOrgMember @relation("KycOrgRelFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   KycOrgMember @relation("KycOrgRelTo", fields: [toMemberId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("kyc_org_relationships")
}

model KycSignal {
  id          BigInt   @id @default(autoincrement())
  companyId   BigInt   @map("company_id")
  source      String
  sourceUrl   String?  @map("source_url") @db.Text
  sentiment   KycSignalSentiment?
  rating      Decimal? @db.Decimal(3, 1)
  title       String?  @db.Text
  text        String?  @db.Text
  signalType  String?  @default("review") @map("signal_type")
  publishedAt DateTime? @map("published_at")
  capturedAt  DateTime  @default(now()) @map("captured_at")

  company KycCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, capturedAt(sort: Desc)])
  @@index([source])
  @@map("kyc_signals")
}

model KycChatSession {
  id          BigInt   @id @default(autoincrement())
  companyId   BigInt   @map("company_id")
  userId      String?  @map("user_id")
  title       String?
  workdir     String?  @db.Text
  sessionType KycChatSessionType @default(research) @map("session_type")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company  KycCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages KycChatMessage[]

  @@index([companyId, updatedAt(sort: Desc)])
  @@map("kyc_chat_sessions")
}

model KycChatMessage {
  id        BigInt   @id @default(autoincrement())
  sessionId BigInt   @map("session_id")
  role      KycChatMessageRole
  content   String   @db.LongText
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  session KycChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  facts   KycFact[]

  @@index([sessionId, id])
  @@map("kyc_chat_messages")
}

model KycFact {
  id            BigInt   @id @default(autoincrement())
  companyId     BigInt   @map("company_id")
  fieldPath     String   @map("field_path")
  value         Json?
  prevValue     Json?    @map("prev_value")
  source        String
  sourceRef     String?  @map("source_ref") @db.Text
  confidence    Decimal? @db.Decimal(3, 2)
  userId        String?  @map("user_id")
  chatMessageId BigInt?  @map("chat_message_id")
  createdAt     DateTime @default(now()) @map("created_at")

  company     KycCompany     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  chatMessage KycChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, fieldPath])
  @@map("kyc_facts")
}

model KycOpenQuestion {
  id         BigInt   @id @default(autoincrement())
  companyId  BigInt   @map("company_id")
  topic      String
  question   String   @db.Text
  priority   Int      @default(2)
  status     KycOpenQuestionStatus @default(open)
  answer     String?  @db.Text
  source     String?  @default("intake")
  createdAt  DateTime @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  company KycCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, priority])
  @@map("kyc_open_questions")
}
